                    # delete from sd
                    echo "Are you sure you want to delete $pkg_name from the SD?"
                    echo -n "Type 'yes' to confirm: "
                    read -r confirm_delete
                    
                    if [ "$confirm_delete" = "yes" ]; then
                        if [ -z "$mountpoint" ]; then
                            echo "SD card is not mounted! Please mount it first."
                            exit
                        fi
                        if [ "$pkg_name" == "SDMenu" ]; then
                            echo "Deleting SDMenu from on the SD card..."
                            rm -rf "$mountpoint/Leapster/System/$pkg_name"
                        else
                            echo "Deleting $pkg_name from on the SD card..."
                            rm -rf "$mountpoint/Leapster/Apps/$pkg_name"
                        fi
