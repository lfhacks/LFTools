            # add packages from directory to list
            scan_packages() {
                local dir=$1
                if [ -d "$dir" ]; then
                    for pkg_dir in "$dir"/*; do
                        if [ -d "$pkg_dir" ]; then
                            packages[$pkg_count]="$pkg_dir"
                            ((pkg_count++))
                        fi
                    done
                fi
            }
            
