            ;;
        c)
            # only use this if device has committed sudoku
            echo "This will attempt to clear all related LFTools files."
            echo "Please do not use this to try to run other commands while the Leapster2/Didj is mounted or unmounted."
            echo "This is only intended for an emergency situation where the Leapster2/Didj has either:"
            echo "1. Disconnected itself for whatever reason"
            echo "2. Frozen"
            echo -n "Please make your choice now. (y/N): "
            read -r clearc
            if [ "$clearc" = 'y' ] || [ "$clearc" = 'Y' ]
            then
                echo "Clearing now..."
                rm -rf ~/.lftools/
                echo "Done. Please run the program again."
                exit
            else
                echo "Aborted."
                exit
            fi
            ;;
        *)
            echo "Invalid! Use -h for usage information."
            exit
     esac
done
