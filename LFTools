                    echo "If it's not mounted, please mount it first."
                    sudo fdisk -l
                    echo -n "Path: "
                    read -r sdpath
                    
                    # Get mount point
                    mountpoint=$(lsblk -o MOUNTPOINT -n "$sdpath" | tr -d '[:space:]' | head -n 1)
                    
                    if [ -z "$mountpoint" ]; then
                        echo "SD card is not mounted! Please mount it first."
                        exit
                    fi
                    
                    # Ensure Apps folder exists
                    if [ ! -d "$mountpoint/Leapster/Apps" ]; then
                        echo "Creating Apps folder on SD card..."
                        mkdir -p "$mountpoint/Leapster/Apps"
                    fi
                    
                    # Determine if it's a System package (SDMenu)
                    if [[ "$selected_pkg" == *"System"* ]] || [[ "$pkg_name" == "SDMenu" ]]; then
                        if [ ! -d "$mountpoint/Leapster/System" ]; then
                            echo "Creating System folder on SD card..."
                            mkdir -p "$mountpoint/Leapster/System"
                        fi
                        echo "Copying $pkg_name to System folder..."
                        cp -r "$selected_pkg" "$mountpoint/Leapster/System/"
                    else
                        echo "Copying $pkg_name to Apps folder..."
                        cp -r "$selected_pkg" "$mountpoint/Leapster/Apps/"
                    fi
                    
                    echo "Done! $pkg_name has been copied to the SD card."
                    ;;
